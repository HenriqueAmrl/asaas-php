{
    "name": "henriqueamrl/asaas-php",
    "description": "PHP SDK for the Asaas payment gateway API (v3) - customers, charges, subscriptions, PIX, and webhooks.",
    "type": "library",
    "keywords": ["asaas", "payment", "sdk", "pix", "boleto", "php"],
    "homepage": "https://github.com/henriqueamrl/asaas-php",
    "license": "MIT",
    "authors": [
        {
            "name": "Henrique Amaral",
            "email": "henriqueamaralreis@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0|^2.0",
        "guzzlehttp/guzzle": "^7.9",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "phpro/grumphp": "^2.16.0",
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "HenriqueAmrl\\AsaasPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HenriqueAmrl\\AsaasPhp\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --test",
        "rector": "vendor/bin/rector process"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "phpro/grumphp": true
        }
    },
    "extra": {
        "grumphp": {
            "config-default-path": "grumphp.yml"
        }
    }
}
