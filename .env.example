# Copy this file to .env and fill in your sandbox credentials.
# Used by: composer test:integration
# Never commit .env — it is gitignored.

# Asaas sandbox API key (from https://sandbox.asaas.com -> Configuracoes -> Integracoes)
ASAAS_API_KEY=your_sandbox_api_key_here

# Webhook token configured in your Asaas sandbox account
ASAAS_WEBHOOK_TOKEN=your_webhook_token_here

# CPF used to create test customers in sandbox (any valid CPF works)
ASAAS_TEST_CPF=11144477735
